# ============================================================
# Turn-Key Motorsport — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your values.

# --- Site ---
NEXT_PUBLIC_SITE_URL=https://turn-key-motorsport.vercel.app

# --- Email (future) ---
# SENDGRID_API_KEY=your_sendgrid_api_key
# RESEND_API_KEY=your_resend_api_key
# CONTACT_EMAIL=info@turnkeymotorsport.com

# --- Square Payments ---
NEXT_PUBLIC_SQUARE_APP_ID=sandbox-sq0idb-XXXXXXXXXXXXXXXXXXXXXXXX
NEXT_PUBLIC_SQUARE_LOCATION_ID=LXXXXXXXXXXXXXXXX
SQUARE_ACCESS_TOKEN=EAAAl...your_sandbox_access_token
SQUARE_ENVIRONMENT=sandbox

# --- Auth (future) ---
# NEXTAUTH_URL=http://localhost:3000
# NEXTAUTH_SECRET=your_random_secret

# --- Admin ---
ADMIN_PASSWORD=your_admin_password_here
ADMIN_SECRET=your_random_hmac_secret_here

# --- Analytics (future) ---
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# --- Google Maps (future) ---
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_key
